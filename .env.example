# Albert (API souveraine Etalab) - OBLIGATOIRE
ALBERT_API_KEY=sk-...
ALBERT_BASE_URL=https://albert.api.etalab.gouv.fr/v1

# Anthropic (Claude Opus) - requis uniquement pour les scripts offline
# (extract_subjects.py, audit anti-hallucination). Pas utilisé en runtime.
ANTHROPIC_API_KEY=sk-ant-...

# App
APP_ENV=dev

# Clé de signature des cookies de session (Starlette SessionMiddleware).
# IMPORTANT en prod : générer une vraie valeur et la stabiliser, sinon
# chaque redémarrage du conteneur invalide les sessions des élèves en cours.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me-in-prod
