# Secrets & env
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Data locale (DB runtime + state d'ingestion) — on ignore tout le contenu
# de data/, sauf data/subjects/ qui contient les sujets DC extraits par Opus
# (artefacts du projet, nécessaires pour peupler la base au démarrage).
# Note : git ne peut pas ré-inclure un fichier si son parent est totalement
# exclu, d'où le pattern data/* (et non data/) ci-dessous.
data/*
!data/subjects/
*.db
*.db-journal
*.sqlite
*.sqlite3

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Docker
.dockerignore.local
data/subjects/_all.json
