# Secrets & env
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Data locale (DB runtime + state d'ingestion) — entièrement ignorée.
# Le contenu pédagogique (sujets, annales, programme, méthodo, corrigés)
# est tracké sous content/histoire-geo-emc/ et n'est donc plus sous data/.
data/*
*.db
*.db-journal
*.sqlite
*.sqlite3

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Docker
.dockerignore.local

# Consolidé des sujets (régénéré par scripts/extract_subjects.py)
content/histoire-geo-emc/subjects/_all.json

# Consolidé des exercices français (régénéré par scripts/extract_french_exercises.py)
content/francais/comprehension/exercises/_all.json

# Consolidé des sujets de rédaction (régénéré par scripts/extract_french_redactions.py)
content/francais/redaction/subjects/_all.json
.venv-test/

# Claude Code : config perso (permissions) + lockfile runtime du scheduler
.claude/settings.json
.claude/scheduled_tasks.lock
